<%- include('../partials/header') %>

<main class="container flex-grow-1 py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 pb-3 border-bottom">
        <div>
            <h1 class="mb-1">Painel do Aluno</h1>
            <p class="text-muted fs-5 mb-0">Bem-vindo(a), <strong><%= usuarioLogado.nome %></strong>!</p>
        </div>

        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/aluno/receita/nova" class="btn btn-laranja fw-bold">Cadastrar Nova Receita</a>
            <a href="/aluno/habilidade/nova" class="btn btn-outline-dark fw-bold">Adicionar Habilidade</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100" style="border-color: #F7D488;">
                <div class="card-header fs-5 fw-bold" style="background-color: #F7D488;">
                    Minhas Receitas
                </div>

                <ul class="list-group list-group-flush">
                    <% if (typeof receitas !== 'undefined' && receitas.length > 0) { %>
                        <% receitas.forEach(receita => { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <strong class="fs-5"><%= receita.nome %></strong>

                                <div class="d-flex gap-2">
                                    <a href="/aluno/receita/editar/<%= receita.id %>" class="btn btn-sm btn-borda-laranja">Editar</a>
                                    <a href="/aluno/receita/excluir/<%= receita.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Tem certeza que deseja apagar esta receita?')">Excluir</a>
                                </div>
                            </li>
                        <% }) %>
                    <% } else { %>
                        <li class="list-group-item text-muted py-4 text-center">
                            Você ainda não tem receitas cadastradas.
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100" style="border-color: #F7D488;">
                <div class="card-header fs-5 fw-bold" style="background-color: #F7D488;">
                    Minhas Habilidades
                </div>

                <ul class="list-group list-group-flush">
                    <% if (typeof habilidades !== 'undefined' && habilidades.length > 0) { %>
                        <% habilidades.forEach(hab => { %>
                            <li class="list-group-item py-3">
                                <div class="row g-2 align-items-center">
                                    <div class="col">
                                        <strong class="fs-5"><%= hab.nome %></strong>
                                    </div>
                                    <div class="col-auto">
                                        <form action="/aluno/habilidade/editar/<%= hab.id %>" method="POST" class="d-flex gap-2">
                                            <input type="number" class="form-control form-control-sm" name="nivel" min="0" max="10" required value="<%= hab.aluno_habilidades ? hab.aluno_habilidades.nivel : 0 %>">
                                            <button type="submit" class="btn btn-sm btn-borda-laranja">Salvar</button>
                                        </form>
                                    </div>
                                    <div class="col-auto">
                                        <form action="/aluno/habilidade/excluir/<%= hab.id %>" method="POST" onsubmit="return confirm('Remover esta habilidade?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        <% }) %>
                    <% } else { %>
                        <li class="list-group-item text-muted py-4 text-center">
                            Nenhuma habilidade cadastrada.
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
