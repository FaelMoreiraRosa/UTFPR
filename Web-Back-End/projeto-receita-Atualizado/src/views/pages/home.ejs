<%- include('../partials/header') %>

<main class="container flex-grow-1 py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4 border-bottom pb-3">
        <div>
            <h1 class="mb-1">Receitas dos Alunos</h1>
            <p class="text-muted mb-0">Portfólio público de receitas cadastradas pelos alunos.</p>
        </div>

        <form action="/" method="GET" class="d-flex gap-2 align-items-end">
            <div>
                <label for="categoria" class="form-label fw-bold mb-1">Filtrar por categoria</label>
                <select id="categoria" name="categoria" class="form-select">
                    <option value="">Todas</option>
                    <% if (typeof categorias !== 'undefined') { %>
                        <% categorias.forEach(categoria => { %>
                            <option value="<%= categoria.id %>" <%= String(categoriaSelecionada) === String(categoria.id) ? 'selected' : '' %>>
                                <%= categoria.nome %>
                            </option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            <button type="submit" class="btn btn-laranja fw-bold">Filtrar</button>
        </form>
    </div>

    <% if (receitas.length === 0) { %>
        <div class="alert alert-warning">Nenhuma receita encontrada.</div>
    <% } else { %>
        <div class="row g-4">
            <% receitas.forEach(receita => { %>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <% if (receita.imagem) { %>
                            <img src="/uploads/<%= receita.imagem %>" alt="Foto de <%= receita.nome %>" style="width: 100%; height: 200px; object-fit: cover;">
                        <% } else { %>
                            <img src="/img/receita-padrao.jpg" alt="Sem foto" style="width: 100%; height: 200px; object-fit: cover;">
                        <% } %>
                        <div class="card-body d-flex flex-column">
                            <h2 class="h5 card-title"><%= receita.nome %></h2>
                            <p class="card-text flex-grow-1"><%= receita.descricao %></p>
                            <p class="card-text small text-muted">
                                <strong>Categorias:</strong>
                                <% const cats = receita.Categorias || receita.Categoria || []; %>
                                <% if (cats.length > 0) { %>
                                    <%= cats.map(c => c.nome).join(', ') %>
                                <% } else { %>
                                    Sem categoria
                                <% } %>
                            </p>
                            <a href="/receita/<%= receita.id %>" class="btn btn-laranja">Ver receita completa</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</main>

<%- include('../partials/footer') %>
