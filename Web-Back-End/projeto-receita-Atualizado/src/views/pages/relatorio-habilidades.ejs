<%- include('../partials/header') %>

<main class="container flex-grow-1 py-4">
    <div class="mb-4 border-bottom pb-3">
        <h1 class="mb-1">Relatório de Habilidades</h1>
        <p class="text-muted mb-0">Proporção de alunos que dominam cada habilidade cadastrada.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-bold" style="background-color: #F7D488;">
            Total de alunos: <%= totalAlunos %>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-orange">
                    <tr>
                        <th>Habilidade</th>
                        <th>Alunos que declararam</th>
                        <th>Proporção</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (relatorio.length > 0) { %>
                        <% relatorio.forEach(item => { %>
                            <tr>
                                <td><%= item.nome %></td>
                                <td><%= item.quantidade %> de <%= item.totalAlunos %></td>
                                <td style="min-width: 220px;">
                                    <div class="progress" role="progressbar" aria-valuenow="<%= item.proporcao %>" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar" style="width: <%= item.proporcao %>%; background-color: #e58d32;">
                                            <%= item.proporcao %>%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-center text-muted">Nenhuma habilidade cadastrada.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
